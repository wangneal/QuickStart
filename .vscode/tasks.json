{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:rust:debug",
      "type": "cargo",
      "command": "build",
      "args": ["--manifest-path=src-tauri/Cargo.toml"],
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "start:vite:dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^(.*VITE.*|.*vite.*)",
          "endsPattern": "^(.*Local:.*)"
        }
      },
      "presentation": {
        "group": "tauri",
        "close": true
      }
    },
    {
      "label": "tauri:dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["tauri", "dev"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "tauri:build",
      "type": "shell",
      "command": "pnpm",
      "args": ["tauri", "build"],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "clear": true
      }
    }
  ]
}
